# Copier ce fichier vers .env et compléter les valeurs avant de lancer docker compose

# --- Base de données ---
POSTGRES_DB=urbanflow
POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://urbanflow:changeme@postgres:5432/urbanflow

# --- Authentification (JWT + refresh tokens, partie 3.10 du dossier) ---
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- Moteur de routage ---
OTP_URL=http://otp:8080/otp/routers/default

# --- Services tiers (service de scoring, partie 7.3 du dossier) ---
WEATHER_API_KEY=
WEATHER_API_URL=

# --- Frontend ---
VITE_API_URL=http://localhost:3000
